generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Instructor {
  id      Int    @id @default(autoincrement())
  name    String
  email   String @unique
  zip     String
  country String
  city    String

  courses Course[]
}

model Course {
  id        Int      @id @default(autoincrement())
  title     String
  desc      String
  duration  Float
  createdAt DateTime @default(now())

  instructorId Int
  instructor   Instructor @relation(fields: [instructorId], references: [id])

  videos Video[]
}

model Video {
  id    Int    @id @default(autoincrement())
  title String
  desc  String
  url   String

  courseId Int
  course   Course @relation(fields: [courseId], references: [id])
}
